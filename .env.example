# 数据库（Sealos 会自动填）
DATABASE_URL=""

# JWT 密钥（必填！随机生成，例如：openssl rand -hex 32）
JWT_SECRET=""

# AES 加密密钥（必填！必须恰好 32 个字符）
ENCRYPTION_KEY=""

# 允许跨域的前端域名，多个用逗号分隔（不填则开发模式全放行）
# 示例：ALLOWED_ORIGINS="https://crm.example.com,https://admin.example.com"
ALLOWED_ORIGINS=""

# 阿里云 OSS
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET="rec-upload-hz"
OSS_REGION="oss-cn-hangzhou"

# AI 配置
AI_DEFAULT_PROVIDER="openai"
AI_DEFAULT_MODEL="gpt-4"
AI_API_URL="https://api.openai.com/v1"
AI_API_KEY=""

# 服务端口
PORT=3000
